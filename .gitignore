node_modules/
dist/
build/
.turbo/
.DS_Store
*.log
.env
.env.local
coverage/
.svelte-kit/
playwright-report/
test-results/

# tsc build artifacts emitted in-place: the library preset has no outDir, and
# packages are consumed as TS source (main → src/index.ts), so `tsc -p` (run by
# turbo's ^build) emits .js/.d.ts next to the .ts source. Never commit these.
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# TLS material — never commit private keys. `tailscale cert` drops <name>.crt/.key
# into the cwd; serve uses the daemon's own store, so these copies aren't needed.
*.key
*.crt
*.pem

# Vite writes a transient timestamp shim next to its config during builds
vite.config.ts.timestamp-*
