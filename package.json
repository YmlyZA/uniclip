{
  "name": "uniclip",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test --filter=!@uniclip/e2e",
    "test:e2e": "pnpm --filter @uniclip/e2e test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev --parallel"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "pnpm": {
    "patchedDependencies": {
      "werift@0.23.0": "patches/werift@0.23.0.patch"
    }
  }
}
